{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@openclaw-enhanced/memory-core": [
        "bamdra-openclaw-memory/packages/memory-core/src/index.ts"
      ],
      "@openclaw-enhanced/memory-sqlite": [
        "bamdra-openclaw-memory/packages/memory-sqlite/src/index.ts"
      ],
      "@openclaw-enhanced/memory-cache-memory": [
        "bamdra-openclaw-memory/packages/memory-cache-memory/src/index.ts"
      ],
      "@openclaw-enhanced/topic-router": [
        "bamdra-openclaw-memory/packages/topic-router/src/index.ts"
      ],
      "@openclaw-enhanced/context-assembler": [
        "bamdra-openclaw-memory/packages/context-assembler/src/index.ts"
      ],
      "@openclaw-enhanced/fact-extractor": [
        "bamdra-openclaw-memory/packages/fact-extractor/src/index.ts"
      ],
      "@openclaw-enhanced/summary-refresher": [
        "bamdra-openclaw-memory/packages/summary-refresher/src/index.ts"
      ],
      "@openclaw-enhanced/bamdra-memory-context-engine": [
        "bamdra-openclaw-memory/packages/bamdra-memory-context-engine/src/index.ts"
      ]
    },
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": [
      "ES2022"
    ]
  }
}
