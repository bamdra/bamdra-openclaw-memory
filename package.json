{
  "name": "openclaw-enhanced",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.0",
  "workspaces": [
    "bamdra-openclaw-memory/packages/*",
    "bamdra-openclaw-memory/plugins/*",
    "bamdra-openclaw-memory/skills/*",
    "bamdra-user-bind",
    "bamdra-memory-vector",
    "bamdra-site"
  ],
  "scripts": {
    "build": "pnpm --dir ./bamdra-openclaw-memory build && pnpm --dir ./bamdra-user-bind run bundle && pnpm --dir ./bamdra-memory-vector run bundle",
    "clean": "find . -name dist -type d -prune -exec rm -rf {} + && find . -name tsconfig.tsbuildinfo -delete",
    "package:release": "node ./scripts/package-release.mjs",
    "typecheck": "pnpm --dir ./bamdra-openclaw-memory typecheck",
    "test": "pnpm typecheck && pnpm build && node --test bamdra-openclaw-memory/tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
