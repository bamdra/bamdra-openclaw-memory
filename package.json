{
  "name": "openclaw-enhanced",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.0",
  "workspaces": [
    "bamdra-*/packages/*",
    "bamdra-*/plugins/*",
    "bamdra-*/skills/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "find . -name dist -type d -prune -exec rm -rf {} +",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm typecheck && pnpm build && node --test bamdra-*/tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "redis": "^5.11.0",
    "typescript": "^5.9.2"
  }
}
