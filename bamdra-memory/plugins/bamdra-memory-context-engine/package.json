{
  "name": "@openclaw-enhanced/bamdra-memory-context-engine",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "bundle": "tsup && cp ../../packages/memory-sqlite/src/schema.sql ./dist/ && node ../../../scripts/prepare-plugin-dist.mjs bamdra-memory-context-engine"
  },
  "openclaw": {
    "id": "bamdra-memory-context-engine",
    "type": "context-engine",
    "slot": "memory",
    "capabilities": [
      "memory"
    ],
    "manifest": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@openclaw-enhanced/context-assembler": "workspace:*",
    "@openclaw-enhanced/fact-extractor": "workspace:*",
    "@openclaw-enhanced/memory-cache-memory": "workspace:*",
    "@openclaw-enhanced/memory-core": "workspace:*",
    "@openclaw-enhanced/memory-sqlite": "workspace:*",
    "@openclaw-enhanced/summary-refresher": "workspace:*",
    "@openclaw-enhanced/topic-router": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2"
  }
}
