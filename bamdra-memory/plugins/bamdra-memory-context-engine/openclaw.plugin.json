{
  "id": "bamdra-memory-context-engine",
  "type": "context-engine",
  "kind": "memory",
  "slot": "memory",
  "capabilities": ["memory"],
  "name": "Bamdra Memory Context Engine",
  "description": "Topic-aware session context orchestration for OpenClaw",
  "main": "./dist/index.js",
  "configSchema": {
    "type": "object"
  },
  "uiHints": {
    "enabled": {
      "label": "Enable Memory V2"
    },
    "store.path": {
      "label": "SQLite Path",
      "placeholder": "~/.openclaw/memory/main.sqlite"
    }
  }
}
